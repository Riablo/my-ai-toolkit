#!/usr/bin/env bash
set -euo pipefail

# ─── 颜色 ────────────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
RESET='\033[0m'

# ─── 配置 ────────────────────────────────────────────────────────
CONFIG_DIR="${HOME}/.config/pingcode-cli"
CONFIG_FILE="${CONFIG_DIR}/config"
CACHE_FILE="${CONFIG_DIR}/bugs_cache.json"

die() { echo -e "${RED}错误：$1${RESET}" >&2; exit 1; }

# ─── 状态映射 ─────────────────────────────────────────────────────
# 状态名 → state_id
declare -A STATE_MAP=(
  [待处理]=5f3a1c2fc2742c538a7dcbcb
  [处理中]=5f3a1c2fc2742cef1d7dcbcc
  [已修复]=5f3a1c2fc2742c20e17dcbcd
  [重新打开]=5f3a1c2fc2742c17f27dcbce
  [挂起]=5f3a1c2fc2742c5fc47dcbd1
)

# state_id → 状态名
declare -A STATE_NAME_MAP=(
  [5f3a1c2fc2742c538a7dcbcb]=待处理
  [5f3a1c2fc2742cef1d7dcbcc]=处理中
  [5f3a1c2fc2742c20e17dcbcd]=已修复
  [5f3a1c2fc2742c17f27dcbce]=重新打开
  [5f3a1c2fc2742c5fc47dcbd1]=挂起
)

# ─── 配置校验与初始化 ─────────────────────────────────────────────
ensure_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    echo -e "${YELLOW}首次使用，需要初始化配置。${RESET}"
    echo ""
    init_config
    return
  fi

  # 校验必要字段
  local missing=()
  for key in base_url session_cookie project_id view_id; do
    local val
    val="$(config_get "$key")"
    if [ -z "$val" ]; then
      missing+=("$key")
    fi
  done

  if [ ${#missing[@]} -gt 0 ]; then
    echo -e "${YELLOW}配置文件缺少以下字段：${missing[*]}${RESET}"
    echo -e "请编辑 ${CYAN}${CONFIG_FILE}${RESET} 补全配置，或删除后重新初始化。"
    exit 1
  fi
}

init_config() {
  mkdir -p "$CONFIG_DIR"

  echo -e "${BOLD}请从浏览器复制 cURL 命令：${RESET}"
  echo ""
  echo -e "  1. 打开 PingCode 缺陷列表页面"
  echo -e "  2. 按 F12 打开开发者工具 → Network 标签"
  echo -e "  3. 刷新页面，找到 ${CYAN}content${RESET} 请求"
  echo -e "  4. 右键该请求 → ${CYAN}Copy → Copy as cURL${RESET}"
  echo -e "  5. 粘贴到下方（会自动解析所有配置）"
  echo ""
  echo -e "${DIM}粘贴 cURL 命令（支持多行，粘贴完按回车）：${RESET}"

  local curl_text=""
  local line
  while IFS= read -r line; do
    # 空行表示输入结束
    [ -z "$line" ] && [ -n "$curl_text" ] && break
    curl_text+="$line"$'\n'
  done

  [ -n "$curl_text" ] || die "输入不能为空"

  # 合并续行符（行尾 \ 连接下一行）
  curl_text="$(echo "$curl_text" | perl -0pe 's/\\\n\s*//g')"

  # 解析 URL → base_url, project_id, view_id
  local full_url
  full_url="$(echo "$curl_text" | grep -oE "https?://[^'\"[:space:]]+" | head -1)"
  [ -n "$full_url" ] || die "无法从 cURL 中解析出 URL"

  local base_url
  base_url="$(echo "$full_url" | grep -oE 'https?://[^/]+')"

  local project_id
  project_id="$(echo "$full_url" | grep -oE '/projects/([a-f0-9]+)/' | sed 's|/projects/||;s|/||')"
  [ -n "$project_id" ] || die "无法从 URL 中解析出 project_id"

  local view_id
  view_id="$(echo "$full_url" | grep -oE '/views/([a-f0-9]+)/' | sed 's|/views/||;s|/||')"
  [ -n "$view_id" ] || die "无法从 URL 中解析出 view_id"

  # 解析 session cookie（s-xxx=yyy）
  local session_cookie
  session_cookie="$(echo "$curl_text" | grep -oE 's-[a-f0-9]+=[a-f0-9]+' | head -1)"
  [ -n "$session_cookie" ] || die "无法从 cURL 中解析出会话 Cookie（s-xxx=yyy 格式）"

  # 解析 request body 中的 addon_setting_id
  local addon_setting_id
  addon_setting_id="$(echo "$curl_text" | grep -oE '"addon_setting_id"\s*:\s*"[a-f0-9]+"' | grep -oE '[a-f0-9]{20,}' | head -1)"
  addon_setting_id="${addon_setting_id:-607434d7f10c20001763c188}"

  # 解析 state_ids
  local state_ids
  state_ids="$(echo "$curl_text" | grep -oE '"state_id".*?\]' | grep -oE '[a-f0-9]{24}' | paste -sd',' -)"
  state_ids="${state_ids:-5f3a1c2fc2742c538a7dcbcb,5f3a1c2fc2742c17f27dcbce}"

  echo ""
  echo -e "${BOLD}解析结果：${RESET}"
  echo -e "  ${CYAN}base_url${RESET}=${base_url}"
  echo -e "  ${CYAN}project_id${RESET}=${project_id}"
  echo -e "  ${CYAN}view_id${RESET}=${view_id}"
  echo -e "  ${CYAN}session_cookie${RESET}=****（已隐藏）"
  echo -e "  ${CYAN}addon_setting_id${RESET}=${addon_setting_id}"
  echo -e "  ${CYAN}state_ids${RESET}=${state_ids}"

  cat > "$CONFIG_FILE" <<EOF
# PingCode CLI 配置文件
# 实例 URL
base_url=${base_url}
# 会话 Cookie（s-xxx=yyy 格式）
session_cookie=${session_cookie}
# 项目 ID
project_id=${project_id}
# 视图 ID
view_id=${view_id}
# 未解决状态 ID（逗号分隔）
state_ids=${state_ids}
# addon_setting_id
addon_setting_id=${addon_setting_id}
EOF

  chmod 600 "$CONFIG_FILE"
  echo ""
  echo -e "${GREEN}配置已保存到 ${CONFIG_FILE}${RESET}"
}

config_get() {
  local key="$1"
  grep -E "^${key}=" "$CONFIG_FILE" 2>/dev/null | head -1 | sed "s/^${key}=//"
}

# ─── API 请求 ─────────────────────────────────────────────────────
api_post() {
  local endpoint="$1"
  local data="$2"
  local base_url session_cookie http_code body
  base_url="$(config_get base_url)"
  session_cookie="$(config_get session_cookie)"

  # 获取 HTTP 状态码和响应体
  local tmpfile
  tmpfile="$(mktemp)"
  http_code="$(curl -s -w '%{http_code}' -o "$tmpfile" \
    "${base_url}${endpoint}" \
    -H 'Accept: application/json, text/plain, */*' \
    -H 'Content-Type: application/json' \
    -H 'Cache-Control: no-cache' \
    -b "${session_cookie}" \
    --data-raw "$data")"

  body="$(cat "$tmpfile")"
  rm -f "$tmpfile"

  if [ "$http_code" -ge 400 ] 2>/dev/null; then
    echo -e "${RED}HTTP ${http_code}${RESET}" >&2
    echo "$body" >&2
    return 1
  fi

  echo "$body"
}

# ─── bugs 命令 ─────────────────────────────────────────────────────
cmd_bugs() {
  local debug=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --debug) debug=1; shift ;;
      *) break ;;
    esac
  done

  ensure_config

  local project_id view_id addon_setting_id state_ids
  project_id="$(config_get project_id)"
  view_id="$(config_get view_id)"
  addon_setting_id="$(config_get addon_setting_id)"
  state_ids="$(config_get state_ids)"

  # 构建 state_id 条件的 JSON 数组
  local state_json="[]"
  if [ -n "$state_ids" ]; then
    state_json="$(echo "$state_ids" | tr ',' '\n' | sed 's/.*/"&"/' | paste -sd',' - | sed 's/^/[/;s/$/]/')"
  fi

  local page_size="${1:-50}"

  local payload
  payload=$(cat <<ENDJSON
{"addon_setting_id":"${addon_setting_id}","criteria":{"search":{"keywords":"","scopes":["identifier","title"]},"condition_logic":1,"sort_by":"identifier","sort_direction":1,"conditions":[{"operation":6,"property_key":"assignee","value":[{"id":"00000000000000000000000000000000","type":1}],"logic":1},{"operation":6,"property_key":"state_id","value":${state_json},"logic":1},{"operation":4,"property_key":"created_at","value":1735660800,"logic":1}],"mode":1,"pql":"","pql_snapshot":{},"group_by":"","show_type":2,"sort_type":1},"columns":["identifier","title","state_id","priority","assignee","parent_id","severity","reappear_probability","created_at"],"is_brief":1,"pi":0,"ps":${page_size}}
ENDJSON
)

  local endpoint="/api/agile/projects/${project_id}/defect/views/${view_id}/content"

  echo -e "${DIM}正在获取缺陷列表...${RESET}"

  local response
  response="$(api_post "$endpoint" "$payload")" || {
    echo -e "${RED}请求失败。可能是会话过期，请重新复制 cURL 更新配置：${RESET}"
    echo -e "  pingcode-cli config init"
    exit 1
  }

  if [ "$debug" -eq 1 ]; then
    echo -e "${BOLD}原始响应：${RESET}"
    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
    echo ""
  fi

  # 缓存响应（供 set-state 等命令使用）
  echo "$response" > "$CACHE_FILE"

  local base_url
  base_url="$(config_get base_url)"

  # 解析并展示
  echo "$response" | STATE_NAMES="$(declare -p STATE_NAME_MAP)" python3 -c "
import json, sys, os, re

data = json.load(sys.stdin)
# 响应结构：{code, data: {value: [...]}}
inner = data.get('data', data)
items = inner.get('value', [])
total = inner.get('total_count', len(items))

# 解析 state_id → 名称映射
state_names = {}
env = os.environ.get('STATE_NAMES', '')
for m in re.finditer(r'\[([^\]]+)\]=(\S+)', env):
    state_names[m.group(1)] = m.group(2)

if not items:
    print('没有找到缺陷。')
    sys.exit(0)

print(f'\033[1m共 {total} 个未解决缺陷：\033[0m')
print()

for item in items:
    short_id = item.get('short_id', item.get('identifier', ''))
    title = item.get('title', '')
    whole_id = item.get('whole_identifier', '')
    state_id = item.get('state_id', '')
    state_name = state_names.get(state_id, state_id[:8])
    url = '${base_url}/pjm/workitems/' + str(short_id)
    print(f'  \033[36m{whole_id:<18}\033[0m \033[33m{state_name:<8}\033[0m {title}')
    print(f'  \033[2m{url}\033[0m')
    print()
"
}

# ─── set-state 命令 ────────────────────────────────────────────────
# 从缓存中通过 short_id 或 whole_identifier 查找 _id
resolve_work_item_id() {
  local query="$1"
  [ -f "$CACHE_FILE" ] || return 1

  python3 -c "
import json, sys

query = '$query'
with open('$CACHE_FILE') as f:
    data = json.load(f)

inner = data.get('data', data)
items = inner.get('value', [])

for item in items:
    sid = item.get('short_id', '')
    wid = item.get('whole_identifier', '')
    if query == sid or query == wid or query == str(item.get('identifier', '')):
        print(item['_id'])
        sys.exit(0)

sys.exit(1)
" 2>/dev/null
}

cmd_set_state() {
  [ $# -ge 2 ] || {
    echo -e "${BOLD}用法：${RESET}pingcode-cli set-state <缺陷编号> <状态>"
    echo ""
    echo -e "${BOLD}缺陷编号：${RESET}short_id（如 CFzSq6-n）或 whole_identifier（如 720YUN-10515）"
    echo ""
    echo -e "${BOLD}可用状态：${RESET}"
    echo -e "  待处理  处理中  已修复  重新打开  挂起"
    return 1
  }

  local query="$1"
  local target_state="$2"

  ensure_config

  # 校验状态名
  local state_id="${STATE_MAP[$target_state]:-}"
  if [ -z "$state_id" ]; then
    echo -e "${RED}未知状态：${target_state}${RESET}"
    echo -e "可用状态：待处理  处理中  已修复  重新打开  挂起"
    return 1
  fi

  # 查找 _id
  local work_item_id
  work_item_id="$(resolve_work_item_id "$query")" || {
    echo -e "${DIM}缓存中未找到 ${query}，正在刷新缺陷列表...${RESET}"
    # 静默刷新列表
    cmd_bugs > /dev/null 2>&1
    work_item_id="$(resolve_work_item_id "$query")" || die "找不到缺陷：${query}\n请确认编号是否正确（可通过 pingcode-cli bugs 查看）"
  }

  echo -e "${DIM}正在将 ${CYAN}${query}${DIM} 设为 ${YELLOW}${target_state}${DIM}...${RESET}"

  local payload="{\"state_id\":\"${state_id}\",\"work_item_ids\":[\"${work_item_id}\"],\"bypass\":0}"

  local response
  response="$(api_post "/api/agile/work-items/state" "$payload")" || {
    echo -e "${RED}操作失败。可能是会话过期，请重新复制 cURL 更新配置：${RESET}"
    echo -e "  pingcode-cli config init"
    exit 1
  }

  echo -e "${GREEN}已将 ${CYAN}${query}${GREEN} 设为 ${YELLOW}${target_state}${GREEN}${RESET}"
}

# ─── config 命令 ───────────────────────────────────────────────────
cmd_config() {
  local subcmd="${1:-show}"
  shift 2>/dev/null || true

  case "$subcmd" in
    show)
      if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${DIM}尚未初始化配置。运行 pingcode-cli config init${RESET}"
        return
      fi
      echo -e "${BOLD}当前配置（${CONFIG_FILE}）：${RESET}"
      echo ""
      while IFS= read -r line; do
        # 跳过空行
        [ -z "$line" ] && continue
        # 注释行
        if [[ "$line" == \#* ]]; then
          echo -e "  ${DIM}${line}${RESET}"
        elif [[ "$line" == session_cookie=* ]]; then
          # 隐藏敏感值
          echo -e "  ${CYAN}session_cookie${RESET}=****（已隐藏）"
        else
          echo -e "  ${CYAN}${line%%=*}${RESET}=${line#*=}"
        fi
      done < "$CONFIG_FILE"
      echo ""
      ;;
    init)
      init_config
      ;;
    edit)
      "${EDITOR:-vi}" "$CONFIG_FILE"
      ;;
    path)
      echo "$CONFIG_FILE"
      ;;
    *)
      die "未知子命令：$subcmd。可用：show, init, edit, path"
      ;;
  esac
}

# ─── 帮助 ────────────────────────────────────────────────────────
usage() {
  echo -e "${BOLD}pingcode-cli${RESET} - PingCode 命令行工具

${BOLD}用法：${RESET}
  pingcode-cli <命令> [参数]

${BOLD}命令：${RESET}
  bugs                          列出我的未解决缺陷
  set-state <编号> <状态>       修改缺陷状态
  config                        管理配置（show|init|edit|path）

${BOLD}可用状态：${RESET}
  待处理  处理中  已修复  重新打开  挂起

${BOLD}选项：${RESET}
  -h, --help      显示此帮助信息

${BOLD}示例：${RESET}
  pingcode-cli bugs                              # 列出未解决缺陷
  pingcode-cli set-state 720YUN-10515 已修复      # 标记为已修复
  pingcode-cli set-state CFzSq6-n 处理中          # 标记为处理中
  pingcode-cli config init                        # 重新初始化配置"
}

# ─── 主入口 ──────────────────────────────────────────────────────
case "${1:-}" in
  bugs)
    shift
    case "${1:-}" in -h|--help) usage; exit 0;; esac
    cmd_bugs "$@"
    ;;
  set-state)
    shift
    case "${1:-}" in -h|--help) cmd_set_state; exit 0;; esac
    cmd_set_state "$@"
    ;;
  config)
    shift
    case "${1:-}" in -h|--help) usage; exit 0;; esac
    cmd_config "$@"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    die "未知命令：$1。使用 pingcode-cli -h 查看帮助。"
    ;;
esac
